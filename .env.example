# Chatwoot Configuration
CHATWOOT_API_URL=https://chatwoot.example.com
CHATWOOT_API_TOKEN=your-token
CHATWOOT_ACCOUNT_ID=1

# Evolution API Configuration
EVOLUTION_API_URL=https://evolution.example.com
EVOLUTION_API_TOKEN=your-token
EVOLUTION_INSTANCE_NAME=your-instance

# Database Configuration
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=campanhas_db
DB_HOST=db
DB_PORT=5432

# Redis Configuration
REDIS_HOST=redis
REDIS_PORT=6379

# App Configuration
BACKEND_PORT=3000
FRONTEND_PORT=3001
NODE_ENV=development

# API URLs
# Para local development: http://localhost:3000
# Para Docker (interno): http://campaign-backend:3000
NEXT_PUBLIC_API_URL=http://localhost:3000
API_URL=http://localhost:3000

# Backend Public URL (para construir URLs absolutas de mídias)
# Usado quando enviando para serviços externos como Chatwoot/Evolution
# Local: http://localhost:3000
# Docker: http://campaign-backend:3000
# Produção: https://seu-dominio.com
BACKEND_PUBLIC_URL=http://localhost:3000
